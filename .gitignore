# Ignore logs
/logs/
Log.txt
PLAN.md
bug.md
bugfix_log.md
prompt.md

# Ignore uploaded files & temporary visual assets
/backend/storage/images/*.png
/backend/storage/workspace/*.json

# Ignore local model configuration keys (contains active API keys)
/backend/storage/*.json

# Python caching
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Environment variables
.env
.env.*
.venv/
env/
venv/
ENV/

# Editor files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
